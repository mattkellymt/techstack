#!/bin/bash
set -euo pipefail 

# fedora 44
sudo dnf upgrade -y
sudo dnf install -y dnf5-plugins

if ! dnf repoinfo gh-cli &> /dev/null; then
	sudo dnf config-manager addrepo --from-repofile="https://cli.github.com/packages/rpm/gh-cli.repo"
fi

sudo dnf group install -y development-tools
sudo dnf install -y \
	vim pass git gh jq yq bubblewrap gawk zstd cmake libcurl-devel

# github
mkdir -p ~/github.com/mattkellymt
cd ~/github.com/mattkellymt

if [ ! -d techstack ]; then
	git clone https://github.com/mattkellymt/techstack.git
fi

cd ~/github.com/mattkellymt/techstack/fedora
git fetch origin main
current_branch=$(git branch --show-current)

if [ "$current_branch" = "main" ]; then
    git reset --hard origin/main
    git clean -fd
fi

# brew
if ! command -v brew &> /dev/null; then
	curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash
fi

# uv
if ! command -v uv &> /dev/null; then
	curl -LsSf https://astral.sh/uv/install.sh | bash
fi

cd ~/github.com/mattkellymt/techstack
uv sync

# opencode
if ! command -v opencode &> /dev/null; then
	brew install anomalyco/tap/opencode
fi

# codex
if ! command -v codex &> /dev/null; then
	brew install codex
fi

# claude
if ! command -v claude &> /dev/null; then
	brew install claude-code
fi

# gemini
if ! command -v gemini &> /dev/null; then
	brew install gemini-cli
fi

# grok
if ! command -v grok &> /dev/null; then
	curl -fsSL https://x.ai/cli/install.sh | bash
fi

# ollama
if ! command -v ollama &> /dev/null; then
	curl -fsSL https://ollama.com/install.sh | bash
fi 

# unsloth
if ! command -v unsloth &> /dev/null; then
	curl -fsSL https://unsloth.ai/install.sh | bash
fi 

# linking
mkdir -p ~/.local/bin
ln -sf ~/github.com/mattkellymt/techstack/fedora/stack ~/.local/bin/stack
ln -sf ~/.opencode/bin/opencode ~/.local/bin/opencode
ln -sf /home/linuxbrew/.linuxbrew/Homebrew/bin/brew ~/.local/bin/brew
