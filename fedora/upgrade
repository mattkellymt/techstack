#!/bin/bash
set -euo pipefail 

# fedora 44
sudo dnf upgrade -y

# github
cd ~/github.com/mattkellymt/techstack
git fetch origin main
current_branch=$(git branch --show-current)

if [ "$current_branch" = "main" ]; then
    git reset --hard origin/main
    git clean -fd
fi

# brew
brew update
brew upgrade

# uv
cd ~/github.com/mattkellymt/techstack
uv self update
uv tool upgrade --all
uv sync --upgrade

# opencode
brew upgrade anomalyco/tap/opencode

# codex
brew upgrade codex

# claude
brew upgrade claude-code

# gemini
brew upgrade antigravity-cli

# ollama
curl -fsSL https://ollama.com/install.sh | sh

# unsloth
curl -fsSL https://unsloth.ai/install.sh | sh
