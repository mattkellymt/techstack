#!/bin/bash
set -eo pipefail 

main() {
	# fedora 44
	sudo dnf upgrade -y
	sudo dnf install -y dnf5-plugins
	
	sudo dnf config-manager addrepo --overwrite --from-repofile="https://cli.github.com/packages/rpm/gh-cli.repo"
	
	sudo dnf group install -y development-tools
	sudo dnf install -y \
		vim pass git gh jq yq bubblewrap gawk zstd cmake libcurl-devel
	
	# profile
	mkdir -p ~/.local/bin
	
	# github
	mkdir -p ~/github.com/mattkellymt
	cd ~/github.com/mattkellymt
	
	if [ ! -d techstack ]; then
		git clone https://github.com/mattkellymt/techstack.git
	fi
	
	cd ~/github.com/mattkellymt/techstack/fedora
	git fetch origin main
	current_branch=$(git branch --show-current)
	
	if [ "$current_branch" = "main" ]; then
	    git reset --hard origin/main
	    git clean -fd
	fi
	
	ln -sf ~/github.com/mattkellymt/techstack/fedora/stack ~/.local/bin/stack
	
	# brew
	if ! command -v brew &> /dev/null; then
		curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash
		echo >> /home/${USER}/.bashrc
		echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"' >> /home/${USER}/.bashrc
		eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
		source /home/${USER}/.bashrc
	fi
	
	# uv
	if ! command -v uv &> /dev/null; then
		brew install -y uv
	fi
	
	cd ~/github.com/mattkellymt/techstack
	uv sync
	
	# opencode
	if ! command -v opencode &> /dev/null; then
		brew tap anomalyco/tap
		brew trust anomalyco/tap
		brew install -y anomalyco/tap/opencode
	fi
	
	# codex
	if ! command -v codex &> /dev/null; then
		brew install -y --cask codex
	fi
	
	# claude
	if ! command -v claude &> /dev/null; then
		brew install -y --cask claude-code
	fi
	
	# gemini
	if ! command -v gemini &> /dev/null; then
		brew install -y --cask antigravity-cli
	fi
	
	# grok
	if ! command -v grok &> /dev/null; then
		curl -fsSL https://x.ai/cli/install.sh | bash
		source /home/${USER}/.bashrc
	fi
	
	# ollama
	if ! command -v ollama &> /dev/null; then
		curl -fsSL https://ollama.com/install.sh | bash
		source /home/${USER}/.bashrc
	fi 
	
	# unsloth
	if ! command -v unsloth &> /dev/null; then
		curl -fsSL https://unsloth.ai/install.sh | UNSLOTH_SKIP_AUTOSTART=1 bash
		source /home/${USER}/.bashrc
	fi 
}

main
