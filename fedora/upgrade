#!/bin/bash
set -eo pipefail 

main() {
    # fedora 44
    sudo dnf upgrade -y --refresh
    
    # github
    cd ~/github.com/mattkellymt/techstack
    git fetch origin main
    current_branch=$(git branch --show-current)
    
    if [ "$current_branch" = "main" ]; then
        git reset --hard origin/main
        git clean -fd
    fi
    
    # brew
    brew update
    brew upgrade -y
    
    # uv
    cd ~/github.com/mattkellymt/techstack
    uv tool upgrade --all
    uv sync --upgrade
    
    # ollama
    curl -fsSL https://ollama.com/install.sh | sh
    
    # unsloth
    curl -fsSL https://unsloth.ai/install.sh | UNSLOTH_SKIP_AUTOSTART=1 bash
}
main
