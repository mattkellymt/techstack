#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$HOME/github.com/mattkellymt/techstack/fedora-nspawn"
bridge_name="br0"

netdev=$(cat <<EOF
[NetDev]
Name=${bridge_name}
Kind=bridge
EOF
)

network=$(cat <<EOF
[Match]
Name=${bridge_name}

[Network]
Address=10.0.0.1/24
DHCPServer=yes
IPMasquerade=ipv4
ConfigureWithoutCarrier=yes
EOF
)

main() {
	# dnf
	sudo dnf upgrade -y --refresh

	# systemd-nspawn container tooling
	sudo dnf install -y systemd-container systemd-resolved

	# ensure container networking + DNS are enabled and running (idempotent)
	sudo systemctl enable --now systemd-networkd
	sudo systemctl enable --now systemd-resolved

	# write + install the container bridge config (10.0.0.1/24, DHCP server + NAT)
	tmp=$(mktemp)
	echo "$netdev"  > "$tmp"
	sudo install -m 644 "$tmp" /etc/systemd/network/${bridge_name}.netdev
	echo "$network" > "$tmp"
	sudo install -m 644 "$tmp" /etc/systemd/network/${bridge_name}.network
	rm -f "$tmp"
	sudo networkctl reload

	# build the default nspawn machine (idempotent)
	"$SCRIPT_DIR/create_machine"
}
main
