#!/bin/bash
set -euo pipefail 

# fedora 44
sudo dnf upgrade -y
sudo dnf group install -y development-tools
sudo dnf install -y \
	vim pass git jq yq bubblewrap gawk dnf5-plugins zstd cmake libcurl-devel

# repo
mkdir -p ~/github.com/mattkellymt
cd ~/github.com/mattkellymt

if [ ! -d techstack ]; then
	git clone https://github.com/mattkellymt/techstack.git
fi

cd ~/github.com/mattkellymt/techstack/fedora
git fetch origin main
current_branch=$(git branch --show-current)

if [ "$current_branch" = "main" ]; then
    git reset --hard origin/main
    git clean -fd
fi

chmod +x setup
chmod +x upgrade
chmod +x stack

# brew
if ! command -v brew &> /dev/null; then
	curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | sh
fi

# uv
if ! command -v uv &> /dev/null; then
	curl -LsSf https://astral.sh/uv/install.sh | sh
fi

cd ~/github.com/mattkellymt/techstack
uv sync

# gh
if ! command -v gh &> /dev/null; then
	url="https://cli.github.com/packages/rpm/gh-cli.repo"
	sudo dnf config-manager addrepo --from-repofile="$url"
	sudo dnf install -y gh
fi

# opencode
if ! command -v opencode &> /dev/null; then
	curl -fsSL https://opencode.ai/install | sh
fi

# codex
if ! command -v codex &> /dev/null; then
	brew install --cask codex
fi

# claude
if ! command -v claude &> /dev/null; then
	curl -fsSL https://claude.ai/install.sh | sh
fi

# gemini
if ! command -v gemini &> /dev/null; then
	brew install gemini-cli
fi

# grok
if ! command -v grok &> /dev/null; then
	curl -fsSL https://x.ai/cli/install.sh | sh
fi

# ollama
if ! command -v ollama &> /dev/null; then
	curl -fsSL https://ollama.com/install.sh | sh
fi 

# unsloth
if ! command -v unsloth &> /dev/null; then
	curl -fsSL https://unsloth.ai/install.sh | sh
fi 

# linking
mkdir -p ~/.local/bin
ln -sf ~/github.com/mattkellymt/techstack/fedora/stack ~/.local/bin/stack
ln -sf /home/linuxbrew/.linuxbrew/bin/brew ~/.local/bin/brew
ln -sf ~/.opencode/bin/opencode ~/.local/bin/opencode
