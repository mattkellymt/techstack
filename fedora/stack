#!/bin/bash
set -eo pipefail

SCRIPT_DIR="$HOME/github.com/mattkellymt/techstack/fedora"

usage=$(cat <<EOF
Usage: stack <command>

Commands:
  setup    Install and configure the software stack
  upgrade  Upgrade all tools
EOF
)

case "${1:-}" in
	setup)
		exec "$SCRIPT_DIR/setup"
		;;
	upgrade)
		exec "$SCRIPT_DIR/upgrade"
		;;
	--help|-h|"")
		echo "$USAGE"
		;;
	*)
		echo "stack: unknown command '$1'" >&2
		echo "$usage" >&2
		exit 1
		;;
esac
