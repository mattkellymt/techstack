#!/bin/bash
set -euo pipefail 

# fedora 44
sudo dnf upgrade -y

# brew
brew update
brew upgrade

# repo
cd ~/github.com/mattkellymt/techstack
git fetch origin main
current_branch=$(git branch --show-current)

if [ "$current_branch" = "main" ]; then
    git reset --hard origin/main
    git clean -fd
fi

# uv
cd ~/github.com/mattkellymt/techstack
uv self update
uv tool upgrade --all
uv sync --upgrade

# opencode
opencode upgrade

# codex
brew upgrade --cask codex

# claude
claude update

# gemini
brew upgrade --cask gemini-cli

# ollama
curl -fsSL https://ollama.com/install.sh | sh

# unsloth
curl -fsSL https://unsloth.ai/install.sh | sh
