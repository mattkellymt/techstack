#!/bin/bash
set -euo pipefail

image_name="fedora"
bridge_name="br0"
os_ver="44"

USAGE=$(cat <<EOF
Usage: create [options]

Options:
  --image_name NAME     Machine image name (default: ${image_name})
  --bridge_name NAME  Bridge to attach to (default: ${bridge_name})
  --ver VER           Fedora release version (default: ${os_ver})
EOF
)

while [ $# -gt 0 ]; do
	case "$1" in
		--image_name)    image_name="$2";    shift 2 ;;
		--bridge_name) bridge_name="$2"; shift 2 ;;
		--ver)         os_ver="$2";      shift 2 ;;
		--help|-h) echo "$USAGE"; exit 0 ;;
		*) echo "create: unknown option '$1'" >&2; echo "$USAGE" >&2; exit 1 ;;
	esac
done

nspawn=$(cat <<EOF
[Exec]
NotifyReady=yes

[Network]
Bridge=${bridge_name}
EOF
)

install_os() {
	local image_name="$1"
	local os_ver="$2"
	local os_root="/var/lib/machines/${image_name}"

	sudo rm -rf "$os_root"
	sudo dnf -y --installroot="$os_root" --releasever="$os_ver" \
		--use-host-config --setopt=install_weak_deps=False \
		install systemd systemd-networkd systemd-resolved dbus-broker coreutils bash fedora-release
	sudo systemctl --root="$os_root" enable systemd-networkd systemd-resolved
	sudo ln -sf ../run/systemd/resolve/stub-resolv.conf "$os_root/etc/resolv.conf"
	sudo systemd-machine-id-setup --root="$os_root"

	local tmp
	tmp=$(mktemp)
	echo "$nspawn" > "$tmp"
	sudo install -m 644 "$tmp" /etc/systemd/nspawn/${image_name}.nspawn
	rm -f "$tmp"
}

if ! sudo machinectl image-status "$image_name" &>/dev/null; then
	install_os "$image_name" "$os_ver"
fi
