#!/bin/bash
set -euo pipefail

TECHSTACK_DIR="$HOME/github.com/mattkellymt/techstack"

case "${1:-}" in
    setup|--setup)
        exec "$TECHSTACK_DIR/setup"
        ;;
    upgrade|--upgrade)
        exec "$TECHSTACK_DIR/upgrade"
        ;;
    ""|-h|--help)
        cat <<EOF
Usage: stack <command>

Commands:
    setup       Install and configure the software stack
    upgrade     Upgrade all tools
EOF
        ;;
    *)
        echo "stack: unknown command '$1'" >&2
        exit 1
        ;;
esac
