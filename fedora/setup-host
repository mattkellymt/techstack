#!/bin/bash
set -eo pipefail

SCRIPT_DIR="$HOME/github.com/mattkellymt/techstack/fedora"
bridge_name="bridge-0"

netdev=$(cat <<EOF
[NetDev]
Name=${bridge_name}
Kind=bridge
EOF
)

network=$(cat <<EOF
[Match]
Name=${bridge_name}

[Network]
Address=10.0.0.1/24
DHCPServer=yes
IPMasquerade=ipv4
ConfigureWithoutCarrier=yes
EOF
)

main() {
	# dnf
	sudo dnf upgrade -y --refresh
	sudo dnf install -y \
		vim neovim python3-neovim git curl htop pass \
		systemd-container systemd-resolved

	# ensure container networking + DNS are enabled and running (idempotent)
	sudo systemctl enable --now systemd-networkd
	sudo systemctl enable --now systemd-resolved

	# write + install the container bridge config (10.0.0.1/24, DHCP server + NAT)
	tmp=$(mktemp)
	echo "$netdev"  > "$tmp"
	sudo install -m 644 "$tmp" /etc/systemd/network/${bridge_name}.netdev
	echo "$network" > "$tmp"
	sudo install -m 644 "$tmp" /etc/systemd/network/${bridge_name}.network
	rm -f "$tmp"
	sudo networkctl reload

	# brew
	if ! command -v brew &> /dev/null; then
		curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh | bash
		echo >> "$HOME/.bashrc"
		echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"' >> "$HOME/.bashrc"
		eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
		source "$HOME/.bashrc"
	fi

	brew install -y jq yq

	# github
	mkdir -p "$HOME/github.com/mattkellymt"
	cd "$HOME/github.com/mattkellymt"

	if [ ! -d techstack ]; then
		git clone https://github.com/mattkellymt/techstack.git
	fi

	cd "$HOME/github.com/mattkellymt/techstack/fedora"
	git fetch origin main
	current_branch=$(git branch --show-current)

	if [ "$current_branch" = "main" ]; then
		git reset --hard origin/main
		git clean -fd
	fi

	mkdir -p "$HOME/.local/bin"
	ln -sf "$HOME/github.com/mattkellymt/techstack/fedora/stack" "$HOME/.local/bin/stack"

	# agents
	for agent in {opencode,codex,claude,antigravity,grok}; do
		"$SCRIPT_DIR/create_$agent" --image_name "$agent" --bridge_name "$bridge_name"
	done
}
main
